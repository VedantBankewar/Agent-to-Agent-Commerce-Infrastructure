# AgentTrade Environment Configuration
# Copy to .env and fill in values

# ---------------------------------------------------------------------------
# AI / LLM
# ---------------------------------------------------------------------------
# Anthropic API key for LangChain agents
ANTHROPIC_API_KEY=sk-ant-...

# Preferred model
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Algorand
# ---------------------------------------------------------------------------
# Algorand Testnet token (leave empty for public API, or use your own)
ALGORAND_TOKEN=

# Algorand Testnet API node
ALGOD_ADDRESS=https://testnet-api.algonode.cloud

# Algorand Testnet Indexer
ALGOD_INDEXER=https://testnet-indexer.algonode.cloud

# Escrow contract app ID (set after deploying contracts/deploy.py)
ESCROW_APP_ID=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# Database path
DATABASE_PATH=db/hackathon.db

# Agreement documents
AGREEMENTS_DIR=agreements

# Delivery proofs
DELIVERY_DIR=delivery

# Agent reasoning logs
LOGS_DIR=logs

# Wallet keys
KEYS_DIR=keys
